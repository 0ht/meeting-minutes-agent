# Copy this file to terraform.tfvars and fill in your values.
resource_group_name = "rg-meeting-minutes-agent"
location            = "japaneast"
environment         = "dev"
app_name            = "mtgminutes"

# Azure OpenAI
openai_sku                 = "S0"
openai_model_name          = "gpt-5.4"
openai_model_version       = "2026-03-05"
openai_deployment_capacity = 30

# Storage
storage_account_tier     = "Standard"
storage_replication_type = "LRS"

# Networking
vnet_address_space         = "10.0.0.0/16"
container_apps_subnet_cidr = "10.0.0.0/23"

# Container Registry
acr_sku = "Basic"

# Container Apps resource allocation
backend_cpu     = 0.5
backend_memory  = "1Gi"
frontend_cpu    = 0.5
frontend_memory = "1Gi"

