# ── Azure Speech (Fast Transcription) ────────────────────────────────────────
AZURE_SPEECH_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com

# ── Azure AI Foundry (推奨) ──────────────────────────────────────────────────
# Foundry プロジェクトエンドポイント。設定すると Foundry 経由で OpenAI モデルを呼び出す。
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api
FOUNDRY_MODEL_DEPLOYMENT=gpt-5.4

# ── Azure OpenAI (レガシーフォールバック) ─────────────────────────────────────
# FOUNDRY_PROJECT_ENDPOINT が未設定の場合にフォールバックとして使用される。
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── Azure Blob Storage (Managed Identity) ────────────────────────────────────
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=audio-files

# ── 用語辞書 (Blob Storage) ──────────────────────────────────────────────────
AZURE_TERMS_CONTAINER=terms
AZURE_TERMS_BLOB=terminology.json
TERMINOLOGY_CACHE_TTL_SECONDS=300

# ── 履歴 (Blob Storage) ─────────────────────────────────────────────────────
AZURE_HISTORY_CONTAINER=history

# ── App Settings ─────────────────────────────────────────────────────────────
MAX_AUDIO_SIZE_MB=100
SPEECH_POLL_TIMEOUT_SECONDS=300
SPEECH_POLL_INTERVAL_SECONDS=5
