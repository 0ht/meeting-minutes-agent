# ── Azure Speech (Fast Transcription) ────────────────────────────────────────
AZURE_SPEECH_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure Blob Storage (Managed Identity) ────────────────────────────────────
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=audio-files

# ── App Settings ─────────────────────────────────────────────────────────────
MAX_AUDIO_SIZE_MB=100
SPEECH_POLL_TIMEOUT_SECONDS=300
SPEECH_POLL_INTERVAL_SECONDS=5
